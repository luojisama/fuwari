---
import "@fontsource-variable/jetbrains-mono";
import "@fontsource-variable/jetbrains-mono/wght-italic.css";

interface Props {
	class: string;
}
const className = Astro.props.class;
---
<div data-pagefind-body class={`prose dark:prose-invert prose-base !max-w-none custom-md ${className}`}>
	<slot />
</div>

<script>
interface ExecuteResponse {
	ok: boolean;
	output?: string;
	stdout?: string;
	stderr?: string;
	error?: string;
}

type StdinMode = "line" | "token";

interface StdinProfile {
	count: number;
	mode: StdinMode;
	prompts: string[];
}

interface StdinSession {
	values: string[];
}

const COPY_RESET_MS = 1000;
const CLIENT_TIMEOUT_MS = 15000;
const copyResetTimers = new WeakMap<HTMLButtonElement, ReturnType<typeof setTimeout>>();
const stdinSessions = new WeakMap<HTMLElement, StdinSession>();
const SUBMIT_INPUT_ICON =
	'<svg viewBox="0 -960 960 960" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M120-160v-640l760 320-760 320Zm80-120 474-200-474-200v140l240 60-240 60v140Z"></path></svg>';

function getActionButton(target: EventTarget | null): HTMLButtonElement | null {
	if (!(target instanceof Element)) return null;
	const button = target.closest("button[data-run-action]");
	return button instanceof HTMLButtonElement ? button : null;
}

function getRunnerBlock(button: HTMLButtonElement): HTMLElement | null {
	const block = button.closest("[data-code-runner]");
	return block instanceof HTMLElement ? block : null;
}

function getCodeElement(block: HTMLElement): HTMLElement | null {
	const code = block.querySelector("pre code");
	if (code instanceof HTMLElement) return code;
	const pre = block.querySelector("pre");
	return pre instanceof HTMLElement ? pre : null;
}

function getEditor(block: HTMLElement): HTMLTextAreaElement | null {
	const editor = block.querySelector("[data-run-editor]");
	return editor instanceof HTMLTextAreaElement ? editor : null;
}

function getStdin(block: HTMLElement): HTMLTextAreaElement | null {
	const stdin = block.querySelector("[data-run-stdin]");
	return stdin instanceof HTMLTextAreaElement ? stdin : null;
}

function getStdinPanel(block: HTMLElement): HTMLElement | null {
	const panel = block.querySelector("[data-run-stdin-panel]");
	if (panel instanceof HTMLElement) return panel;
	return getStdin(block);
}

function getRunButton(block: HTMLElement): HTMLButtonElement | null {
	const button = block.querySelector('button[data-run-action="run"]');
	return button instanceof HTMLButtonElement ? button : null;
}

function getRunButtons(block: HTMLElement): HTMLButtonElement[] {
	return [
		...block.querySelectorAll(
			'button[data-run-action="run"], button[data-run-action="submit-input"]',
		),
	].filter(
		(button): button is HTMLButtonElement => button instanceof HTMLButtonElement,
	);
}

function getOutput(block: HTMLElement): HTMLElement | null {
	const output = block.querySelector("[data-run-output]");
	return output instanceof HTMLElement ? output : null;
}

function getCode(block: HTMLElement): string {
	const editor = getEditor(block);
	if (editor && !editor.hidden) return editor.value;
	return getCodeElement(block)?.innerText ?? "";
}

function getStdinSession(block: HTMLElement): StdinSession {
	const session = stdinSessions.get(block);
	if (session) return session;

	const nextSession = { values: [] };
	stdinSessions.set(block, nextSession);
	return nextSession;
}

function readStringLiteral(text: string): string {
	try {
		return JSON.parse(`"${text}"`) as string;
	} catch (_error) {
		return text.replace(/\\n/g, "\n").replace(/\\"/g, '"');
	}
}

function getLastQuotedText(line: string): string {
	const matches = [...line.matchAll(/"((?:\\.|[^"\\])*)"/g)];
	const last = matches.at(-1);
	return last ? readStringLiteral(last[1]) : "";
}

function getJavaInputPrompts(code: string): string[] {
	const prompts: string[] = [];
	let pendingPrompt = "";

	for (const line of code.split(/\r?\n/)) {
		if (/System\.out\.print(?:ln)?\s*\(/.test(line)) {
			const text = getLastQuotedText(line);
			if (text) pendingPrompt = text;
		}
		if (/\.\s*next(?:Int|Long|Double|Float|Boolean|Byte|Short|Line)?\s*\(/.test(line)) {
			prompts.push(pendingPrompt);
			pendingPrompt = "";
		}
	}

	return prompts;
}

function getCSharpInputPrompts(code: string): string[] {
	const prompts: string[] = [];
	let pendingPrompt = "";

	for (const line of code.split(/\r?\n/)) {
		if (/Console\.Write(?:Line)?\s*\(/.test(line)) {
			const text = getLastQuotedText(line);
			if (text) pendingPrompt = text;
		}
		if (/\bConsole\.Read(?:Line|Key)\s*\(/.test(line)) {
			prompts.push(pendingPrompt);
			pendingPrompt = "";
		}
	}

	return prompts;
}

function getPythonInputPrompts(code: string): string[] {
	return [...code.matchAll(/\binput\s*\(\s*(?:"((?:\\.|[^"\\])*)"|'((?:\\.|[^'\\])*)')?/g)].map(
		(match) => readStringLiteral(match[1] ?? match[2] ?? ""),
	);
}

function detectStdinProfile(block: HTMLElement): StdinProfile {
	const language = block.dataset.runLanguage?.toLowerCase() ?? "";
	const code = getCode(block);

	if (language === "java") {
		const prompts = getJavaInputPrompts(code);
		return {
			count: prompts.length,
			mode: /\.\s*nextLine\s*\(/.test(code) ? "line" : "token",
			prompts,
		};
	}

	if (language === "python" || language === "py") {
		const prompts = getPythonInputPrompts(code);
		return { count: prompts.length, mode: "line", prompts };
	}

	if (language === "csharp" || language === "cs") {
		const prompts = getCSharpInputPrompts(code);
		return { count: prompts.length, mode: "line", prompts };
	}

	return { count: 0, mode: "line", prompts: [] };
}

function splitSubmittedValues(values: string[], mode: StdinMode): string[] {
	if (mode === "token") {
		return values.join("\n").trim().split(/\s+/).filter(Boolean);
	}

	return values.flatMap((value) => value.replace(/\r\n?/g, "\n").split("\n"));
}

function getSubmittedCount(values: string[], mode: StdinMode): number {
	return splitSubmittedValues(values, mode).length;
}

function getExpectedStdinCount(profile: StdinProfile): number {
	return profile.count > 0 ? profile.count : 1;
}

function renderTerminalPreview(profile: StdinProfile, values: string[]): string {
	const entries = splitSubmittedValues(values, profile.mode);
	const expected = getExpectedStdinCount(profile);
	const lines: string[] = [];

	for (let index = 0; index < entries.length; index++) {
		const prompt = profile.prompts[index];
		if (prompt) lines.push(prompt);
		lines.push(`> ${entries[index]}`);
	}

	if (entries.length < expected) {
		const nextPrompt = profile.prompts[entries.length];
		lines.push(nextPrompt || `Input ${entries.length + 1}/${expected}`);
	}

	return lines.join("\n");
}

function getStdinValue(block: HTMLElement): string {
	const session = stdinSessions.get(block);
	const stdin = getStdin(block)?.value ?? "";
	const values = session?.values.length ? [...session.values, stdin] : [stdin];
	return values.filter((value) => value.length > 0).join("\n");
}

function createStdinSubmitButton(): HTMLButtonElement {
	const button = document.createElement("button");
	button.type = "button";
	button.className = "code-tool-btn code-tool-run code-stdin-submit";
	button.title = "Submit input";
	button.setAttribute("aria-label", "Submit input");
	button.dataset.runAction = "submit-input";
	button.innerHTML = SUBMIT_INPUT_ICON;
	return button;
}

function ensureStdinSubmitButton(block: HTMLElement): HTMLElement | null {
	const stdin = getStdin(block);
	if (!stdin) return null;
	stdin.placeholder = "Current input, Enter to submit";

	let panel = block.querySelector("[data-run-stdin-panel]");
	if (!(panel instanceof HTMLElement)) {
		panel = document.createElement("div");
		panel.className = "code-run-stdin-panel";
		panel.dataset.runStdinPanel = "";
		panel.hidden = stdin.hidden;
		stdin.hidden = false;
		stdin.replaceWith(panel);
		panel.append(stdin);
	}

	if (!panel.querySelector(".code-stdin-submit")) {
		panel.append(createStdinSubmitButton());
	}

	return panel;
}

async function copyText(text: string): Promise<boolean> {
	if (navigator.clipboard && window.isSecureContext) {
		try {
			await navigator.clipboard.writeText(text);
			return true;
		} catch (_err) {
			// Fall back for browsers that expose Clipboard API but still reject writes.
		}
	}

	const textarea = document.createElement("textarea");
	textarea.value = text;
	textarea.setAttribute("readonly", "");
	textarea.style.position = "fixed";
	textarea.style.left = "-9999px";
	textarea.style.top = "0";
	document.body.appendChild(textarea);
	textarea.focus();
	textarea.select();

	try {
		return document.execCommand("copy");
	} finally {
		textarea.remove();
	}
}

function setCopyState(button: HTMLButtonElement, copied: boolean) {
	button.classList.toggle("is-success", copied);
	button.classList.toggle("is-error", !copied);

	const resetTimer = copyResetTimers.get(button);
	if (resetTimer) clearTimeout(resetTimer);

	copyResetTimers.set(
		button,
		setTimeout(() => {
			button.classList.remove("is-success", "is-error");
		}, COPY_RESET_MS),
	);
}

function toggleEditor(block: HTMLElement, button: HTMLButtonElement) {
	const editor = getEditor(block);
	const pre = block.querySelector("pre");
	if (!editor || !(pre instanceof HTMLElement)) return;

	if (editor.hidden) {
		editor.value = getCode(block);
		editor.style.minHeight = `${Math.max(120, pre.getBoundingClientRect().height)}px`;
		editor.hidden = false;
		pre.hidden = true;
		button.classList.add("is-active");
	} else {
		editor.hidden = true;
		pre.hidden = false;
		button.classList.remove("is-active");
	}
}

function toggleStdin(block: HTMLElement, button: HTMLButtonElement) {
	const panel = ensureStdinSubmitButton(block) ?? getStdinPanel(block);
	if (!panel) return;
	panel.hidden = !panel.hidden;
	button.classList.toggle("is-active", !panel.hidden);

	if (!panel.hidden) {
		const output = getOutput(block);
		if (output?.hidden) {
			setOutput(
				output,
				renderTerminalPreview(detectStdinProfile(block), getStdinSession(block).values),
				"idle",
			);
		}
	}
}

function setOutput(
	output: HTMLElement,
	text: string,
	state: "idle" | "running" | "error",
) {
	output.hidden = false;
	output.textContent = text;
	output.dataset.state = state;
}

async function runCode(
	block: HTMLElement,
	button: HTMLButtonElement,
	stdinOverride?: string,
) {
	const output = getOutput(block);
	const runButtons = getRunButtons(block);
	if (!output || button.disabled || runButtons.some((runButton) => runButton.disabled)) {
		return;
	}

	const language = block.dataset.runLanguage;
	const code = getCode(block);
	const stdin = stdinOverride ?? getStdinValue(block);
	if (!language || !code.trim()) {
		setOutput(output, "No code to run.", "error");
		return;
	}

	const controller = new AbortController();
	const timeout = setTimeout(() => controller.abort(), CLIENT_TIMEOUT_MS);

	for (const runButton of runButtons) {
		runButton.disabled = true;
		runButton.classList.add("is-running");
	}
	setOutput(output, "Running...", "running");

	try {
		const response = await fetch("/api/execute/", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ code, language, stdin }),
			signal: controller.signal,
		});
		const data = (await response.json()) as ExecuteResponse;

		if (!response.ok || !data.ok) {
			throw new Error(data.error || data.output || response.statusText);
		}

		setOutput(output, data.output?.trimEnd() || "No output", "idle");
	} catch (error) {
		const message =
			error instanceof DOMException && error.name === "AbortError"
				? "Execution timed out."
				: error instanceof Error
					? error.message
					: String(error);
		setOutput(output, `Error: ${message}`, "error");
	} finally {
		clearTimeout(timeout);
		for (const runButton of runButtons) {
			runButton.disabled = false;
			runButton.classList.remove("is-running");
		}
	}
}

async function submitStdin(block: HTMLElement, button: HTMLButtonElement) {
	const stdin = getStdin(block);
	const output = getOutput(block);
	if (!stdin || !output) return;

	const profile = detectStdinProfile(block);
	const session = getStdinSession(block);
	const value = stdin.value;
	if (profile.mode === "token" && !value.trim()) {
		setOutput(output, renderTerminalPreview(profile, session.values), "idle");
		return;
	}

	session.values.push(value);
	stdin.value = "";

	const expected = getExpectedStdinCount(profile);
	const submitted = getSubmittedCount(session.values, profile.mode);
	if (submitted < expected) {
		setOutput(output, renderTerminalPreview(profile, session.values), "idle");
		return;
	}

	const submittedValues = session.values.join("\n");
	session.values = [];
	await runCode(block, button, `${submittedValues}\n`);
}

async function handleStdinKeydown(event: KeyboardEvent) {
	if (event.key !== "Enter" || event.isComposing) return;
	if (!(event.target instanceof HTMLTextAreaElement)) return;
	if (!event.target.matches("[data-run-stdin]")) return;

	const block = event.target.closest("[data-code-runner]");
	if (!(block instanceof HTMLElement)) return;

	ensureStdinSubmitButton(block);
	const button =
		block.querySelector<HTMLButtonElement>('button[data-run-action="submit-input"]') ??
		getRunButton(block);
	if (!button) return;

	event.preventDefault();
	await submitStdin(block, button);
}

function handleStdinFocus(event: FocusEvent) {
	if (!(event.target instanceof HTMLTextAreaElement)) return;
	if (!event.target.matches("[data-run-stdin]")) return;

	const block = event.target.closest("[data-code-runner]");
	if (block instanceof HTMLElement) {
		ensureStdinSubmitButton(block);
		const output = getOutput(block);
		if (output?.hidden) {
			setOutput(
				output,
				renderTerminalPreview(detectStdinProfile(block), getStdinSession(block).values),
				"idle",
			);
		}
	}
}

async function handleCodeToolClick(event: MouseEvent) {
	const button = getActionButton(event.target);
	if (!button) return;

	const block = getRunnerBlock(button);
	if (!block) return;

	const action = button.dataset.runAction;
	if (action === "copy") {
		setCopyState(button, await copyText(getCode(block)));
		return;
	}

	if (action === "edit") {
		toggleEditor(block, button);
		return;
	}

	if (action === "stdin") {
		toggleStdin(block, button);
		return;
	}

	if (action === "submit-input") {
		await submitStdin(block, button);
		return;
	}

	if (action === "run") {
		await runCode(block, button);
		stdinSessions.delete(block);
	}
}

if (!window._codeRunnerBound) {
	document.addEventListener("click", handleCodeToolClick);
	document.addEventListener("keydown", handleStdinKeydown);
	document.addEventListener("focusin", handleStdinFocus);
	window._codeRunnerBound = true;
}
</script>

<style is:global>
.custom-md .code-block {
	position: relative;
	margin: 1rem 0;
}

.custom-md .code-block pre {
	margin: 0;
	padding-top: 3rem;
}

.custom-md .code-block-toolbar {
	position: absolute;
	z-index: 10;
	top: 0.5rem;
	right: 0.5rem;
	display: flex;
	align-items: center;
	gap: 0.35rem;
}

.custom-md .code-block-language {
	display: none;
	padding: 0.3rem 0.55rem;
	border-radius: 0.45rem;
	background: rgb(255 255 255 / 0.08);
	color: rgb(255 255 255 / 0.72);
	font-size: 0.75rem;
	line-height: 1;
}

.custom-md .code-tool-btn {
	display: inline-flex;
	width: 2rem;
	height: 2rem;
	align-items: center;
	justify-content: center;
	border: 0;
	border-radius: 0.45rem;
	background: oklch(0.30 0.02 var(--hue));
	color: rgb(255 255 255 / 0.78);
	opacity: 0.82;
	transition: color 0.15s ease, background-color 0.15s ease, opacity 0.15s ease, transform 0.15s ease;
}

.custom-md .code-tool-btn:hover,
.custom-md .code-tool-btn.is-active {
	color: white;
	opacity: 1;
	background: oklch(0.38 0.04 var(--hue));
}

.custom-md .code-tool-btn:active {
	transform: scale(0.92);
}

.custom-md .code-tool-btn:disabled {
	cursor: wait;
	opacity: 0.6;
}

.custom-md .code-tool-btn.is-success {
	color: var(--deep-text);
	background: var(--primary);
}

.custom-md .code-tool-btn.is-error {
	color: white;
	background: #b91c1c;
}

.custom-md .code-tool-run.is-running svg {
	animation: code-run-spin 0.8s linear infinite;
}

.custom-md .code-run-stdin-panel {
	display: flex;
	align-items: stretch;
	gap: 0.5rem;
	margin-top: 0.5rem;
}

.custom-md .code-run-stdin-panel[hidden] {
	display: none;
}

.custom-md .code-run-editor,
.custom-md .code-run-stdin,
.custom-md .code-run-output {
	width: 100%;
	margin-top: 0.5rem;
	border: 1px solid rgb(255 255 255 / 0.12);
	border-radius: 0.65rem;
	background: #1e1e1e;
	color: #d4d4d4;
	font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
	font-size: 0.875rem;
	line-height: 1.6;
}

.custom-md .code-run-editor,
.custom-md .code-run-stdin {
	padding: 0.75rem;
	resize: vertical;
	outline: none;
}

.custom-md .code-run-stdin-panel .code-run-stdin {
	flex: 1 1 auto;
	min-width: 0;
	margin-top: 0;
}

.custom-md .code-run-stdin-panel .code-stdin-submit {
	flex: 0 0 3rem;
	width: 3rem;
	height: auto;
	align-self: stretch;
}

.custom-md .code-run-output {
	overflow-x: auto;
	white-space: pre-wrap;
	padding: 0.85rem;
}

.custom-md .code-run-output[data-state="running"] {
	color: rgb(212 212 212 / 0.65);
}

.custom-md .code-run-output[data-state="error"] {
	color: #fca5a5;
	border-color: rgb(185 28 28 / 0.55);
}

@media (min-width: 640px) {
	.custom-md .code-block-language {
		display: inline-flex;
	}
}

@keyframes code-run-spin {
	from {
		transform: rotate(0deg);
	}
	to {
		transform: rotate(360deg);
	}
}
</style>
