<!-- Hidden Source Elements for Busuanzi -->
<div
    aria-hidden="true"
    style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden;"
>
    <span id="busuanzi_container_site_pv">
        <span id="busuanzi_value_site_pv"></span>
    </span>
    <span id="busuanzi_container_site_uv">
        <span id="busuanzi_value_site_uv"></span>
    </span>
</div>

<script>
    let syncTimer;
    let retryTimer;
    let syncCount = 0;

    function hasStatsValues() {
        const pv = document.getElementById("busuanzi_value_site_pv")?.textContent?.trim();
        const uv = document.getElementById("busuanzi_value_site_uv")?.textContent?.trim();
        return Boolean(pv) || Boolean(uv);
    }

    function syncStats() {
        const mappings = [
            { id: "busuanzi_container_site_pv", cls: "busuanzi_container_site_pv", isValue: false },
            { id: "busuanzi_value_site_pv", cls: "busuanzi_value_site_pv", isValue: true },
            { id: "busuanzi_container_site_uv", cls: "busuanzi_container_site_uv", isValue: false },
            { id: "busuanzi_value_site_uv", cls: "busuanzi_value_site_uv", isValue: true },
        ];

        for (const mapping of mappings) {
            const source = document.getElementById(mapping.id);
            if (!source) continue;
            const targets = document.getElementsByClassName(mapping.cls);
            for (let i = 0; i < targets.length; i++) {
                const target = targets[i] as HTMLElement;
                if (mapping.isValue) {
                    target.textContent = source.textContent || "";
                } else {
                    target.style.display = hasStatsValues() ? "inline" : "none";
                }
            }
        }
    }

    function startSyncLoop() {
        if (syncTimer) {
            clearInterval(syncTimer);
        }
        syncCount = 0;
        syncStats();
        syncTimer = window.setInterval(() => {
            syncStats();
            syncCount++;
            // Keep syncing for up to 60s, enough for slow third-party responses.
            if (syncCount > 120) {
                clearInterval(syncTimer);
                syncTimer = undefined;
            }
        }, 500);
    }

    function loadBusuanziScript() {
        const scriptUrl = "https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js";
        const oldScript = document.getElementById("busuanzi-script");
        if (oldScript) {
            oldScript.remove();
        }

        const script = document.createElement("script");
        script.id = "busuanzi-script";
        script.src = scriptUrl;
        script.async = true;
        script.onload = () => {
            startSyncLoop();
        };
        script.onerror = () => {
            // Retry once after a short delay for transient CDN failures.
            if (retryTimer) clearTimeout(retryTimer);
            retryTimer = window.setTimeout(() => loadBusuanziScript(), 1500);
        };
        document.body.appendChild(script);
    }

    function initBusuanziStats() {
        startSyncLoop();
        loadBusuanziScript();
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initBusuanziStats, { once: true });
    } else {
        initBusuanziStats();
    }

    document.addEventListener("swup:content:replace", () => {
        initBusuanziStats();
    });
</script>
